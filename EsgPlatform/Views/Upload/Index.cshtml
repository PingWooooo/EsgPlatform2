@model UploadViewModel
@{
    ViewData["Title"] = "數據上傳";
}

<div class="row justify-content-center">
    <div class="col-xl-8">

        <!-- 頁面標題 -->
        <div class="d-flex align-items-center mb-4">
            <div class="rounded-circle p-3 me-3" style="background:#e8f5e9;">
                <i class="bi bi-cloud-upload-fill fs-3 text-success"></i>
            </div>
            <div>
                <h4 class="mb-0 fw-bold">ESG 數據上傳</h4>
                <p class="text-muted mb-0 small">上傳範疇一、二排放數據 Excel，系統將自動計算 CO₂e</p>
            </div>
        </div>

        @if (Model.IsSubmitted)
        {
            <!-- 上傳結果 -->
            <div class="card border-0 shadow-sm mb-4 @(Model.ErrorCount == 0 ? "border-start border-success border-3" : "border-start border-warning border-3")">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">
                        <i class="bi @(Model.ErrorCount == 0 ? "bi-check-circle-fill text-success" : "bi-exclamation-circle-fill text-warning") me-2"></i>
                        上傳結果
                    </h6>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <div class="bg-success bg-opacity-10 rounded p-3 text-center">
                                <div class="fs-2 fw-bold text-success">@Model.SuccessCount</div>
                                <div class="small text-muted">成功匯入筆數</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="bg-danger bg-opacity-10 rounded p-3 text-center">
                                <div class="fs-2 fw-bold text-danger">@Model.ErrorCount</div>
                                <div class="small text-muted">失敗筆數</div>
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Message))
                    {
                        <div class="alert @(Model.ErrorCount == 0 && Model.SuccessCount > 0 ? "alert-success" : "alert-warning") py-2 mb-2">
                            @Model.Message
                        </div>
                    }
                    @if (Model.Errors.Any())
                    {
                        <details class="mt-2">
                            <summary class="text-danger small cursor-pointer">查看 @Model.Errors.Count 筆錯誤詳情</summary>
                            <ul class="list-unstyled mt-2">
                                @foreach (var err in Model.Errors)
                                {
                                    <li class="small text-muted"><i class="bi bi-x-circle text-danger me-1"></i>@err</li>
                                }
                            </ul>
                        </details>
                    }
                </div>
            </div>
        }

        <!-- 上傳表單 -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <form asp-action="Upload" method="post" enctype="multipart/form-data" id="uploadForm">
                    @Html.AntiForgeryToken()

                    <!-- 拖曳上傳區 -->
                    <div class="upload-zone" id="dropZone">
                        <input type="file" name="file" id="fileInput" accept=".xlsx,.xls,.csv" class="d-none" />
                        <div class="text-center py-4" id="dropContent">
                            <i class="bi bi-file-earmark-spreadsheet fs-1 text-success opacity-50"></i>
                            <h5 class="mt-3 text-muted">拖曳 Excel 檔案至此處</h5>
                            <p class="text-muted small mb-3">或點擊下方按鈕選擇檔案</p>
                            <p class="text-muted small">支援格式：.xlsx / .xls / .csv　｜　最大 10 MB</p>
                        </div>
                        <div id="fileInfo" class="text-center py-3 d-none">
                            <i class="bi bi-file-earmark-check fs-2 text-success"></i>
                            <p class="fw-semibold mt-2 mb-0" id="fileName"></p>
                            <p class="small text-muted" id="fileSize"></p>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="button" class="btn btn-outline-success flex-grow-1" onclick="document.getElementById('fileInput').click()">
                            <i class="bi bi-folder2-open me-2"></i>選擇檔案
                        </button>
                        <button type="submit" class="btn btn-success flex-grow-1" id="submitBtn" disabled>
                            <i class="bi bi-cloud-upload me-2"></i>開始上傳並計算
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Excel 格式說明 & 範本下載 -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
                <h6 class="card-title mb-0 fw-semibold">
                    <i class="bi bi-info-circle me-2 text-info"></i>Excel 格式規範
                </h6>
                <a asp-action="DownloadTemplate" class="btn btn-outline-success btn-sm">
                    <i class="bi bi-file-earmark-arrow-down me-1"></i>下載 Excel 範本
                </a>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">第一列為標題列，欄位名稱請依照下表設定：</p>
                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead class="table-success">
                            <tr>
                                <th>欄位名稱（英文）</th>
                                <th>說明</th>
                                <th>範例</th>
                                <th>必填</th>
                            </tr>
                        </thead>
                        <tbody class="small">
                            <tr><td><code>Scope</code></td><td>排放範疇</td><td>1 或 2</td><td><span class="badge bg-danger">必填</span></td></tr>
                            <tr><td><code>Category</code></td><td>排放類別</td><td>固定燃燒源</td><td><span class="badge bg-danger">必填</span></td></tr>
                            <tr><td><code>ItemName</code></td><td>排放項目</td><td>天然氣</td><td><span class="badge bg-danger">必填</span></td></tr>
                            <tr><td><code>Value</code></td><td>活動量數值</td><td>1500.5</td><td><span class="badge bg-danger">必填</span></td></tr>
                            <tr><td><code>Unit</code></td><td>單位</td><td>m³、kWh</td><td><span class="badge bg-secondary">選填</span></td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="alert alert-info py-2 small mb-0">
                    <i class="bi bi-lightbulb me-1"></i>
                    <strong>提示：</strong>Category 與 ItemName 的值必須與「碳排係數設定」中的項目一致，系統才能自動比對並計算 CO₂e。
                </div>
            </div>
        </div>

        <!-- AI 減碳建議區塊 -->
        <div class="card border-0 shadow-sm" id="aiAdviceCard">
            <div class="card-header bg-white border-0 pt-3 d-flex align-items-center">
                <i class="bi bi-robot fs-5 me-2 text-primary"></i>
                <h6 class="card-title mb-0 fw-semibold">AI 減碳建議</h6>
                <span class="badge bg-primary ms-2 fw-normal">GPT</span>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    輸入您的碳排放數據摘要，AI 將分析後提供具體可行的減碳策略建議。
                </p>
                <div class="mb-3">
                    <label class="form-label fw-semibold">碳排放數據摘要</label>
                    <textarea id="emissionSummary" class="form-control" rows="3"
                              placeholder="例：2024年度本公司範疇一排放 120 公噸 CO2e（天然氣佔 60%、柴油 40%），範疇二電力排放 85 公噸 CO2e。..."></textarea>
                </div>
                <button type="button" class="btn btn-primary" id="getAdviceBtn">
                    <i class="bi bi-magic me-1"></i>取得 AI 減碳建議
                </button>
                <div id="aiAdviceResult" class="mt-3 d-none">
                    <hr />
                    <h6 class="fw-semibold text-primary mb-2">
                        <i class="bi bi-lightbulb-fill me-1"></i>AI 建議結果
                    </h6>
                    <div id="aiAdviceText" class="bg-light rounded p-3 small" style="white-space:pre-wrap;"></div>
                </div>
                <div id="aiAdviceSpinner" class="mt-3 d-none text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">載入中...</span>
                    </div>
                    <p class="small text-muted mt-2">AI 正在分析您的碳排放數據...</p>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    const dropZone  = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const submitBtn = document.getElementById('submitBtn');
    const dropContent = document.getElementById('dropContent');
    const fileInfo  = document.getElementById('fileInfo');

    function showFile(file) {
        const sizeMB = (file.size / 1024 / 1024).toFixed(2);
        document.getElementById('fileName').textContent = file.name;
        document.getElementById('fileSize').textContent = `${sizeMB} MB`;
        dropContent.classList.add('d-none');
        fileInfo.classList.remove('d-none');
        submitBtn.disabled = false;
    }

    fileInput.addEventListener('change', function() {
        if (this.files[0]) showFile(this.files[0]);
    });

    dropZone.addEventListener('dragover', e => {
        e.preventDefault();
        dropZone.classList.add('drag-over');
    });

    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));

    dropZone.addEventListener('drop', e => {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (file) {
            // 將 dropped file 附加到 input（透過 DataTransfer）
            const dt = new DataTransfer();
            dt.items.add(file);
            fileInput.files = dt.files;
            showFile(file);
        }
    });

    document.getElementById('uploadForm').addEventListener('submit', function() {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>處理中...';
    });

    // AI 減碳建議
    document.getElementById('getAdviceBtn').addEventListener('click', async function () {
        const summary = document.getElementById('emissionSummary').value.trim();
        if (!summary) {
            alert('請先輸入碳排放數據摘要');
            return;
        }

        const btn     = this;
        const spinner = document.getElementById('aiAdviceSpinner');
        const result  = document.getElementById('aiAdviceResult');
        const text    = document.getElementById('aiAdviceText');

        btn.disabled = true;
        spinner.classList.remove('d-none');
        result.classList.add('d-none');

        try {
            // 取得 AntiForgery token（由 hidden form field 提供）
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const response = await fetch('/Upload/GetAiAdvice', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ summary })
            });
            const data = await response.json();
            text.textContent = data.advice;
            result.classList.remove('d-none');
        } catch (err) {
            text.textContent = '呼叫 AI 服務失敗，請稍後再試。';
            result.classList.remove('d-none');
        } finally {
            btn.disabled = false;
            spinner.classList.add('d-none');
        }
    });
</script>
}
