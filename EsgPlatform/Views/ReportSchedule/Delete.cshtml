@model ReportSchedule
@{
    ViewData["Title"] = "刪除排程";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm border-top border-danger border-3">
            <div class="card-body p-4 text-center">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i>
                <h5 class="mt-3 mb-1 fw-bold">確認刪除排程</h5>
                <p class="text-muted small mb-4">此操作無法復原，相關燈號紀錄也將一併刪除</p>

                <div class="bg-light rounded p-3 mb-4 text-start">
                    <div class="row g-2 small">
                        <div class="col-4 text-muted fw-semibold">報告名稱</div>
                        <div class="col-8">@Model.ReportName</div>
                        <div class="col-4 text-muted fw-semibold">頻率</div>
                        <div class="col-8">@Model.FrequencyDisplayName</div>
                        <div class="col-4 text-muted fw-semibold">負責窗口</div>
                        <div class="col-8">@Model.ResponsiblePerson</div>
                        <div class="col-4 text-muted fw-semibold">下次截止日</div>
                        <div class="col-8">@Model.NextDueDate.ToString("yyyy/MM/dd")</div>
                    </div>
                </div>

                <form asp-action="Delete" method="post" class="d-flex gap-2 justify-content-center">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg me-1"></i>取消
                    </a>
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash3 me-1"></i>確認刪除
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
