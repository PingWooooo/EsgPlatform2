@model IEnumerable<ReportSchedule>
@{
    ViewData["Title"] = "報告排程維護";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center">
        <div class="rounded-circle p-3 me-3" style="background:#e8f5e9;">
            <i class="bi bi-calendar-check-fill fs-3 text-success"></i>
        </div>
        <div>
            <h4 class="mb-0 fw-bold">報告排程維護</h4>
            <p class="text-muted mb-0 small">管理 ESG 報告繳交排程與負責窗口設定（僅限管理員）</p>
        </div>
    </div>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg me-2"></i>新增排程
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-calendar-x fs-1 opacity-25"></i>
                <p class="mt-3">目前尚無排程設定</p>
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-plus-lg me-1"></i>建立第一個排程
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">報告名稱</th>
                            <th>頻率</th>
                            <th>負責窗口</th>
                            <th>警示天數</th>
                            <th>下次截止日</th>
                            <th class="text-center">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            var daysLeft = (s.NextDueDate.ToDateTime(TimeOnly.MinValue) - DateTime.Today).Days;
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-semibold">@s.ReportName</span>
                                </td>
                                <td>
                                    <span class="badge @(s.Frequency == "Monthly" ? "bg-info text-dark" : "bg-purple")">
                                        @s.FrequencyDisplayName
                                    </span>
                                </td>
                                <td>
                                    <i class="bi bi-person me-1 text-muted"></i>@s.ResponsiblePerson
                                </td>
                                <td>
                                    <span class="badge bg-warning text-dark">提前 @s.WarningDays 天</span>
                                </td>
                                <td>
                                    <span class="@(daysLeft < 0 ? "text-danger fw-semibold" : daysLeft <= s.WarningDays ? "text-warning fw-semibold" : "")">
                                        @s.NextDueDate.ToString("yyyy/MM/dd")
                                    </span>
                                    @if (daysLeft >= 0)
                                    {
                                        <small class="text-muted ms-1">（@daysLeft 天後）</small>
                                    }
                                    else
                                    {
                                        <small class="text-danger ms-1">（已逾期 @Math.Abs(daysLeft) 天）</small>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@s.Id" class="btn btn-outline-danger"
                                           onclick="return confirm('確定要刪除排程「@s.ReportName」嗎？此操作無法復原。')">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
