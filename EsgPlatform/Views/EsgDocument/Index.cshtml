@model EsgPlatform.ViewModels.EsgDocumentIndexViewModel
@{
    ViewData["Title"] = "ESG 文件監控看板";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center">
        <div class="rounded-circle p-3 me-3" style="background:#e8f5e9;">
            <i class="bi bi-traffic-light-fill fs-3 text-success"></i>
        </div>
        <div>
            <h4 class="mb-0 fw-bold">ESG 文件監控看板</h4>
            <p class="text-muted mb-0 small">即時顯示所有 ESG 文件的上傳狀態與截止日期</p>
        </div>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Schedules" class="btn btn-outline-success">
            <i class="bi bi-gear me-1"></i>排程維護
        </a>
    }
</div>

<!-- 燈號摘要卡片 -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm text-center py-3" style="border-left: 4px solid #4caf50 !important;">
            <div class="status-dot status-green mx-auto mb-2" style="width:20px;height:20px;"></div>
            <div class="fw-bold fs-3 text-success">@Model.GreenCount</div>
            <div class="small text-muted">綠燈：期限內已上傳</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm text-center py-3" style="border-left: 4px solid #ffc107 !important;">
            <div class="status-dot status-yellow mx-auto mb-2" style="width:20px;height:20px;"></div>
            <div class="fw-bold fs-3 text-warning">@Model.YellowCount</div>
            <div class="small text-muted">黃燈：接近截止未上傳</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm text-center py-3" style="border-left: 4px solid #f44336 !important;">
            <div class="status-dot status-red mx-auto mb-2" style="width:20px;height:20px;"></div>
            <div class="fw-bold fs-3 text-danger">@Model.RedCount</div>
            <div class="small text-muted">紅燈：已逾期未上傳</div>
        </div>
    </div>
</div>

<!-- 文件監控清單 -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="card-title mb-0 fw-semibold">
            <i class="bi bi-list-check me-2 text-success"></i>文件排程清單
        </h6>
    </div>
    <div class="card-body p-0">
        @if (!Model.Schedules.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-calendar-x fs-1 opacity-25"></i>
                <p class="mt-3">尚無文件排程設定</p>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Schedules" class="btn btn-success">
                        <i class="bi bi-plus-circle me-1"></i>新增排程
                    </a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3" style="width:80px;">燈號</th>
                            <th>文件名稱</th>
                            <th>頻率</th>
                            <th>截止日</th>
                            <th>剩餘/逾期</th>
                            <th>最後上傳</th>
                            <th>負責窗口</th>
                            <th class="text-center">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Schedules.OrderBy(x => x.NextDueDate))
                        {
                            <tr class="@(item.TrafficLight == "Red" ? "table-danger bg-opacity-25" :
                                          item.TrafficLight == "Yellow" ? "table-warning bg-opacity-25" : "")">
                                <!-- 第一欄：紅綠燈 -->
                                <td class="ps-3 text-center">
                                    <span class="status-dot status-@item.TrafficLight.ToLower() d-inline-block"
                                          style="width:18px;height:18px;"
                                          title="@item.TrafficLightDisplay"></span>
                                    <div class="small mt-1 @(item.TrafficLight == "Red" ? "text-danger fw-bold" :
                                                              item.TrafficLight == "Yellow" ? "text-warning fw-bold" : "text-success")">
                                        @item.TrafficLightDisplay
                                    </div>
                                </td>
                                <td class="fw-semibold">@item.DocumentName</td>
                                <td>
                                    <span class="badge @(item.Frequency == "Monthly" ? "bg-info text-dark" : "bg-primary")">
                                        @item.FrequencyDisplay
                                    </span>
                                </td>
                                <td>@item.NextDueDate.ToString("yyyy/MM/dd")</td>
                                <td>
                                    @{
                                        var days = item.DaysUntilDue;
                                    }
                                    @if (days < 0)
                                    {
                                        <span class="badge bg-danger">逾期 @Math.Abs(days) 天</span>
                                    }
                                    else if (days == 0)
                                    {
                                        <span class="badge bg-warning text-dark">今天截止</span>
                                    }
                                    else
                                    {
                                        <span class="badge @(days <= item.WarningDays ? "bg-warning text-dark" : "bg-success")">
                                            剩 @days 天
                                        </span>
                                    }
                                </td>
                                <td class="small text-muted">
                                    @(item.LastUploadedAt.HasValue
                                        ? item.LastUploadedAt.Value.ToString("yyyy/MM/dd HH:mm")
                                        : "尚未上傳")
                                </td>
                                <td class="small text-muted">@item.ResponsiblePerson</td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Upload" asp-route-scheduleId="@item.Id"
                                           class="btn btn-outline-success" title="上傳文件">
                                            <i class="bi bi-cloud-upload"></i>
                                        </a>
                                        <a asp-action="UploadHistory" asp-route-scheduleId="@item.Id"
                                           class="btn btn-outline-secondary" title="上傳記錄">
                                            <i class="bi bi-clock-history"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- 燈號說明 -->
<div class="card border-0 bg-light mt-4">
    <div class="card-body py-3">
        <h6 class="fw-semibold mb-2"><i class="bi bi-info-circle me-1 text-info"></i>燈號說明</h6>
        <div class="row g-2 small">
            <div class="col-sm-4">
                <span class="status-dot status-green me-2 d-inline-block" style="width:12px;height:12px;vertical-align:middle;"></span>
                <strong class="text-success">綠燈</strong>：截止日前已上傳文件
            </div>
            <div class="col-sm-4">
                <span class="status-dot status-yellow me-2 d-inline-block" style="width:12px;height:12px;vertical-align:middle;"></span>
                <strong class="text-warning">黃燈</strong>：距截止日 ≤ 預警天數且尚未上傳（月報 7 天、年報 90 天）
            </div>
            <div class="col-sm-4">
                <span class="status-dot status-red me-2 d-inline-block" style="width:12px;height:12px;vertical-align:middle;"></span>
                <strong class="text-danger">紅燈</strong>：已過截止日且未上傳
            </div>
        </div>
    </div>
</div>
